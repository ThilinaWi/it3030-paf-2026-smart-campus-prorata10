# ==========================================
# Smart Campus Operations Hub — .gitignore
# ==========================================

# ---- Java / Spring Boot / Maven ----
backend/target/
*.class
*.jar
*.war
*.ear
*.log
*.pid
*.pid.lock
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# ---- IDE ----
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Node / React / Vite ----
frontend/node_modules/
frontend/dist/
frontend/.cache/
*.tgz

# ---- Environment variables ----
.env
.env.*
!.env.example

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Build outputs ----
build/
dist/
out/

# ---- Coverage ----
coverage/
*.lcov
.nyc_output/

# ---- Misc ----
*.tsbuildinfo
.eslintcache
.stylelintcache

# ---- Vite ----
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
