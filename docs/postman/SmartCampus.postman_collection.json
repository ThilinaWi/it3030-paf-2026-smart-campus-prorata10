  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login With Google Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (e) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data.token) {",
                  "  pm.collectionVariables.set('jwtToken', data.token);",
                  "}",
                  "",
                  "pm.test('JWT token exists in response', function () {",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{googleIdToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Exchanges a Google ID token for backend JWT.\n\nSet collection variable googleIdToken to a valid Google credential token first."
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Response has user email', function () {",
                  "  pm.expect(data.email).to.be.a('string');",
                  "});",
                  "",
                  "if (data.id) {",
                  "  pm.collectionVariables.set('currentUserId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Returns currently authenticated user profile. Requires Bearer token."
          },
          "response": []
        }
      ]
    },
